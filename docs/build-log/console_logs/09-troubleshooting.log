OPTIONS:
   --all, -a                        Show all containers (default: false)
   --id value                       Filter by container id
   --image value                    Filter by container image
   --label value [ --label value ]  Filter by key=value label
   --last value, -n value           Show last n recently created containers (includes all states). Set 0 for unlimited. (default: 0)
   --latest, -l                     Show the most recently created container (includes all states) (default: false)
